---
import Link from '@/components/Link.astro'
import ProjectList from '@/components/ProjectList.astro'
import Section from '@/components/Section.astro'
import SocialIcons from '@/components/SocialIcons.astro'
import { SITE, TAGLINES } from '@/consts'
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Home" description={SITE.DESCRIPTION}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Subtle gradient orb -->
    <div class="pointer-events-none absolute -top-32 left-1/2 -translate-x-1/2 h-full w-full rounded-full bg-accent/[0.04] blur-[120px]" aria-hidden="true"></div>

    <div class="mx-auto max-w-[50rem] px-6 pt-28 pb-20 md:pt-36 md:pb-28">
      <div class="flex flex-col items-center text-center">
        <h1 class="hero-title font-display text-6xl font-extrabold tracking-tight md:text-8xl">
          {SITE.TITLE}
        </h1>
        <p id="tagline" class="hero-tagline max-w-lg text-lg text-muted-foreground leading-relaxed">
          {TAGLINES[0]}
        </p>
        <div class="hero-roles flex items-center gap-3 text-sm text-muted-foreground/50">
          <span>video editor</span>
          <span class="h-1 w-1 rounded-full bg-accent/40"></span>
          <span>web developer</span>
          <span class="h-1 w-1 rounded-full bg-accent/40"></span>
          <span>he/him</span>
        </div>
        <div class="hero-socials pt-4">
          <SocialIcons />
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <Section class="flex flex-col gap-8 pb-20">
    <h2 class="projects-heading font-display text-2xl font-bold tracking-tight">Projects</h2>
    <ProjectList />
  </Section>

</Layout>

<script is:inline define:vars={{ TAGLINES }}>
  document.addEventListener('astro:page-load', () => {
    const el = document.getElementById('tagline')
    if (el) {
      el.textContent = TAGLINES[Math.floor(Math.random() * TAGLINES.length)]
    }
  })
</script>

<style>
  .hero-title {
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-tagline {
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.06s both;
  }
  .hero-roles {
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.12s both;
  }
  .hero-socials {
    animation: fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.18s both;
  }
  .projects-heading {
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.24s both;
  }
  .writing-heading {
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
  }
  .post-row {
    animation: fade-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
