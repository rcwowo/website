---
import Section from '@/components/Section.astro'
import Link from '@/components/Link.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/Layout.astro'
import { cn } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
---

<Layout title="404" description={SITE.DESCRIPTION}>
  <Section class='flex flex-col h-screen items-center justify-center text-center gap-6' last>
    <Icon name="lucide:file-question" width={50} height={50} />
    <div class="max-w-md">
      <h1 class="mb-2 text-3xl font-bold">404</h1>
      <p>
        The page you're looking for doesn't appear to exist.
        Please check your URL or return home. 
      </p>
    </div>
    <Link
      href="/"
      class={cn(
        buttonVariants(),
        'flex gap-x-1.5 group',
      )}
    >
      <span class="transition-transform group-hover:-translate-x-1"
        >&larr;</span
      > Go to home page
    </Link>
  </Section>
</Layout>
