---
import { formatDate } from '@/lib/utils'
import type { CollectionEntry } from 'astro:content'
import Link from '@/components/Link.astro'

type Props = {
  entry: CollectionEntry<'blog'>
}

const { entry } = Astro.props as {
  entry: CollectionEntry<'blog'>
}

const formattedDate = formatDate(entry.data.date)
---

<Link
  href={`/${entry.collection}/${entry.id}`}
  class="group flex items-baseline justify-between gap-4 py-3 transition-colors duration-200 hover:bg-secondary/20 -mx-3 px-3 rounded-lg"
>
  <h3 class="text-sm font-medium text-foreground transition-colors duration-200 group-hover:text-accent truncate min-w-0">
    {entry.data.title}
  </h3>
  <span class="text-xs text-muted-foreground/40 shrink-0 tabular-nums">
    {formattedDate}
  </span>
</Link>
