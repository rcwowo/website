---
import Link from '@/components/Link.astro'
import type { Heading } from './TableOfContents.astro'

const { heading } = Astro.props
const indent = heading.depth > 2
---

<li>
  <Link
    href={'#' + heading.slug}
    class:list={[
      'toc-link block rounded-md px-4 py-1.5 text-[13px] leading-snug text-muted-foreground/60 transition-colors duration-200 hover:text-foreground hover:bg-secondary/40',
      indent && 'pl-8 text-xs',
    ]}
  >
    {heading.text}
  </Link>
  {
    heading.subheadings.length > 0 && (
      <ul>
        {heading.subheadings.map((subheading: Heading) => (
          <Astro.self heading={subheading} />
        ))}
      </ul>
    )
  }
</li>
